<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="OpenClawTray.Chat.Native.ChatTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray.Chat.Native"
    xmlns:chat="using:OpenClaw.Chat"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Per-entry templates. Phase 3 will flesh out ToolCall / Reasoning / Status / PermissionPrompt. -->

        <DataTemplate x:Key="UserBubbleTemplate" x:DataType="chat:ChatTimelineItem">
            <Grid HorizontalAlignment="Right" Margin="48,4,12,4">
                <Border
                    Background="{ThemeResource SystemAccentColorBrush}"
                    CornerRadius="14,14,4,14"
                    Padding="14,10,14,10"
                    MaxWidth="640">
                    <TextBlock
                        Text="{x:Bind Text}"
                        Foreground="White"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantBubbleTemplate" x:DataType="chat:ChatTimelineItem">
            <Grid HorizontalAlignment="Left" Margin="12,4,48,4">
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="14,14,14,4"
                    Padding="14,10,14,10"
                    MaxWidth="720">
                    <tk:MarkdownTextBlock
                        Text="{x:Bind Text}"
                        Background="Transparent" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DefaultEntryTemplate" x:DataType="chat:ChatTimelineItem">
            <Border
                Background="{ThemeResource SubtleFillColorTransparentBrush}"
                Padding="12,4,12,4"
                Margin="12,2,12,2">
                <TextBlock
                    Text="{x:Bind Text}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    IsTextSelectionEnabled="True" />
            </Border>
        </DataTemplate>

        <local:ChatEntryTemplateSelector
            x:Key="EntryTemplateSelector"
            UserTemplate="{StaticResource UserBubbleTemplate}"
            AssistantTemplate="{StaticResource AssistantBubbleTemplate}"
            DefaultTemplate="{StaticResource DefaultEntryTemplate}" />
    </UserControl.Resources>

    <Grid>
        <!-- The timeline. ScrollView (NOT ScrollViewer) is the new WinUI 3 control with
             first-class anchoring support. VerticalAnchorRatio=1.0 keeps the bottom edge
             pinned when content grows; the user has to actively scroll up to break out. -->
        <ScrollView
            x:Name="Scroller"
            ContentOrientation="Vertical"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalAnchorRatio="1.0">
            <ItemsRepeater
                x:Name="Repeater"
                Margin="0,8,0,16"
                ItemTemplate="{StaticResource EntryTemplateSelector}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="4" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollView>

        <!-- Jump-to-bottom FAB. Visibility tracks ChatScrollController.IsAnchored;
             the unread-count pill on its right tracks ChatScrollController.UnreadCount. -->
        <Button
            x:Name="JumpButton"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,20,20"
            CornerRadius="20"
            Padding="14,8,14,8"
            Visibility="Collapsed"
            Background="{ThemeResource AccentFillColorDefaultBrush}"
            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
            Click="OnJumpToBottomClick"
            AutomationProperties.Name="Jump to latest message">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon
                    Glyph="&#xE74B;"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="14" />
                <TextBlock
                    x:Name="UnreadPill"
                    Visibility="Collapsed"
                    FontSize="12"
                    FontWeight="SemiBold" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
