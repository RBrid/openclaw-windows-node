<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="OpenClawTray.Chat.Native.NativeChatRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray.Chat.Native"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource LayerFillColorAlt}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: header (thread title + connection status badge) -->
        <Border
            Grid.Row="0"
            Padding="20,10,20,10"
            BorderThickness="0,0,0,1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="ThreadTitle"
                    Grid.Column="0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />
                <Border
                    x:Name="ConnectionBadge"
                    Grid.Column="1"
                    Padding="8,2,8,2"
                    CornerRadius="10"
                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}">
                    <TextBlock
                        x:Name="ConnectionBadgeText"
                        FontSize="11"
                        FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <!-- Row 1: timeline (or placeholder when no provider/empty) -->
        <Grid Grid.Row="1">
            <local:ChatTimelineView x:Name="Timeline" />

            <StackPanel
                x:Name="EmptyState"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                MaxWidth="420"
                Padding="24">
                <FontIcon
                    Glyph="&#xE8BD;"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="32"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    HorizontalAlignment="Center" />
                <TextBlock
                    x:Name="EmptyStateText"
                    Text="Ready when you are. Type a message below."
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel
                x:Name="LoadingState"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <ProgressRing IsActive="True" Width="28" Height="28" />
                <TextBlock
                    Text="Connecting to gateway…"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Row 2: thinking indicator (visible when turn is active and last entry is not assistant) -->
        <Border
            x:Name="ThinkingRow"
            Grid.Row="2"
            Visibility="Collapsed"
            Padding="20,4,20,4">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressRing IsActive="True" Width="14" Height="14" />
                <TextBlock
                    x:Name="ThinkingText"
                    Text="Assistant is thinking…"
                    FontStyle="Italic"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Row 3: composer -->
        <local:NativeChatComposer x:Name="Composer" Grid.Row="3" />
    </Grid>
</UserControl>
