<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Chat.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray.Chat.Views"
    xmlns:md="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <local:BrushKeyConverter x:Key="BrushKey"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <local:StringToVisibilityConverter x:Key="StringToVis"/>

        <!-- ============= USER ============= -->
        <DataTemplate x:Key="UserTemplate" x:DataType="local:UserItemViewModel">
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="1"
                        MaxWidth="640"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="14,14,4,14"
                        Padding="14,10,14,10">
                    <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ============= ASSISTANT ============= -->
        <DataTemplate x:Key="AssistantTemplate" x:DataType="local:AssistantItemViewModel">
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        VerticalAlignment="Top">
                    <FontIcon Glyph="&#xE99A;" FontSize="14"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </Border>
                <Grid Grid.Column="1" Margin="8,0,0,0">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="14,14,14,4"
                            Padding="14,10,14,10"
                            MaxWidth="780"
                            HorizontalAlignment="Left">
                        <StackPanel Spacing="6">
                            <md:MarkdownTextBlock Text="{x:Bind Text, Mode=OneWay}"
                                                  Background="Transparent"/>
                            <ProgressBar IsIndeterminate="True"
                                         Height="2" MinHeight="2"
                                         Visibility="{x:Bind IsStreaming, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Hover-revealed action strip — kept always visible on first cut. -->
                    <StackPanel Orientation="Horizontal" Spacing="2"
                                HorizontalAlignment="Left"
                                Margin="6,4,0,0"
                                VerticalAlignment="Bottom">
                        <Button Tag="{x:Bind Text, Mode=OneWay}"
                                Click="OnAssistantCopy"
                                Style="{StaticResource SubtleButtonStyle}"
                                Padding="6,2,6,2">
                            <ToolTipService.ToolTip>
                                <ToolTip Content="Copy"/>
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                        </Button>
                        <Button Tag="{x:Bind Text, Mode=OneWay}"
                                Click="OnAssistantReadAloud"
                                Style="{StaticResource SubtleButtonStyle}"
                                Padding="6,2,6,2">
                            <ToolTipService.ToolTip>
                                <ToolTip Content="Read aloud"/>
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE995;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- ============= REASONING ============= -->
        <DataTemplate x:Key="ReasoningTemplate" x:DataType="local:ReasoningItemViewModel">
            <Expander Margin="0,4,0,4"
                      HorizontalAlignment="Stretch"
                      Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                      BorderThickness="0">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7C3;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock Text="Reasoning"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Expander.Header>
                <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True"
                           FontFamily="Consolas"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Expander>
        </DataTemplate>

        <!-- ============= TOOL CALL ============= -->
        <DataTemplate x:Key="ToolCallTemplate" x:DataType="local:ToolCallItemViewModel">
            <Border Margin="0,4,0,4"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8,10,8">
                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind StatusGlyph, Mode=OneWay}"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <TextBlock Text="{x:Bind ToolName, Mode=OneWay}"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind IntentSummary, Mode=OneWay}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind IntentSummary, Mode=OneWay, Converter={StaticResource StringToVis}}"/>
                        </StackPanel>
                        <ProgressRing Grid.Column="2"
                                      Width="14" Height="14"
                                      IsActive="{x:Bind IsInProgress, Mode=OneWay}"
                                      Visibility="{x:Bind IsInProgress, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                    </Grid>

                    <Expander HorizontalAlignment="Stretch"
                              Background="Transparent"
                              BorderThickness="0"
                              Visibility="{x:Bind HasArgs, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Expander.Header>
                            <TextBlock Text="Arguments"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Expander.Header>
                        <TextBlock Text="{x:Bind ArgsPretty, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True"
                                   FontFamily="Consolas"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </Expander>

                    <Expander HorizontalAlignment="Stretch"
                              Background="Transparent"
                              BorderThickness="0"
                              Visibility="{x:Bind HasOutput, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Expander.Header>
                            <TextBlock Text="Output"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Expander.Header>
                        <ScrollViewer MaxHeight="320" HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBlock Text="{x:Bind ToolOutput, Mode=OneWay}"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"
                                       FontFamily="Consolas"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </ScrollViewer>
                    </Expander>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ============= STATUS ============= -->
        <DataTemplate x:Key="StatusTemplate" x:DataType="local:StatusItemViewModel">
            <Border Margin="0,2,0,2"
                    HorizontalAlignment="Center"
                    Padding="8,4,8,4"
                    CornerRadius="10"
                    Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{x:Bind ToneBrushKey, Mode=OneWay, Converter={StaticResource BrushKey}}"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True"/>
            </Border>
        </DataTemplate>

        <!-- ============= PERMISSION ============= -->
        <DataTemplate x:Key="PermissionTemplate" x:DataType="local:PermissionItemViewModel">
            <Border Margin="0,6,0,6"
                    Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                    BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,10,12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE946;" FontSize="14"/>
                        <TextBlock Text="Permission requested"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ToolName, Mode=OneWay}"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind Detail, Mode=OneWay}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,8"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Deny"
                                Tag="{x:Bind RequestId}"
                                Click="OnPermissionDeny"
                                IsEnabled="{x:Bind IsResolved, Mode=OneWay, Converter={StaticResource BoolToVisInv}}"/>
                        <Button Content="Allow"
                                Style="{StaticResource AccentButtonStyle}"
                                Tag="{x:Bind RequestId}"
                                Click="OnPermissionAllow"
                                IsEnabled="{x:Bind IsResolved, Mode=OneWay, Converter={StaticResource BoolToVisInv}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ============= RAW ============= -->
        <DataTemplate x:Key="RawTemplate" x:DataType="local:RawItemViewModel">
            <Border Margin="0,2,0,2" Padding="8" CornerRadius="6"
                    Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True"
                           FontFamily="Consolas"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Border>
        </DataTemplate>

        <!-- ============= TYPING ============= -->
        <DataTemplate x:Key="TypingTemplate" x:DataType="local:TypingItemViewModel">
            <Border Margin="0,4,0,4"
                    Padding="14,10,14,10"
                    HorizontalAlignment="Left"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="14,14,14,4">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing Width="14" Height="14" IsActive="True"/>
                    <TextBlock Text="Thinking…"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <local:ChatItemTemplateSelector x:Key="ItemTemplateSelector"
            UserTemplate="{StaticResource UserTemplate}"
            AssistantTemplate="{StaticResource AssistantTemplate}"
            ReasoningTemplate="{StaticResource ReasoningTemplate}"
            ToolCallTemplate="{StaticResource ToolCallTemplate}"
            StatusTemplate="{StaticResource StatusTemplate}"
            PermissionTemplate="{StaticResource PermissionTemplate}"
            RawTemplate="{StaticResource RawTemplate}"
            TypingTemplate="{StaticResource TypingTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Padding="20,12,20,12"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderTitleText"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                    <TextBlock x:Name="MessageCountText" Grid.Column="1"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
                <TextBlock x:Name="HeaderBreadcrumbText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"/>
                <TextBlock x:Name="IntentText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           Visibility="Collapsed"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"/>
            </StackPanel>
        </Border>

        <!-- TIMELINE -->
        <ListView x:Name="TimelineList"
                  Grid.Row="1"
                  Padding="20,12,20,12"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  ShowsScrollingPlaceholders="False"
                  ItemTemplateSelector="{StaticResource ItemTemplateSelector}"
                  ScrollViewer.IsHorizontalScrollChainingEnabled="False"
                  ScrollViewer.HorizontalScrollMode="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

        <!-- COMPOSER -->
        <Border Grid.Row="2"
                Padding="20,10,20,12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid ColumnSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8" Grid.ColumnSpan="2">
                    <ComboBox x:Name="ModelPicker"
                              MinWidth="180"
                              PlaceholderText="Model"
                              SelectionChanged="OnModelChanged"/>
                    <ToggleSwitch x:Name="AllowAllToggle"
                                  OnContent="Allow all" OffContent="Ask"
                                  Toggled="OnAllowAllToggled"/>
                </StackPanel>

                <TextBox x:Name="InputBox" Grid.Row="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60" MaxHeight="180"
                         PlaceholderText="Send a message — Enter to send, Shift+Enter for newline"
                         KeyDown="OnInputKeyDown"
                         TextChanged="OnInputTextChanged"/>
                <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Bottom">
                    <Button x:Name="StopButton"
                            Click="OnStopClick"
                            Visibility="Collapsed">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="Stop response"/>
                        </ToolTipService.ToolTip>
                        <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                    </Button>
                    <Button x:Name="SendButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="OnSendClick"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE724;" FontSize="14"/>
                            <TextBlock Text="Send"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DISCONNECTED OVERLAY -->
        <Grid x:Name="EmptyOverlay" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <FontIcon Glyph="&#xE8BD;" FontSize="40"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="Connecting…"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
